# LINE Bot 設定（到 LINE Developers Console 申請）
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# 管理後台密碼
ADMIN_PASSWORD=admin123

# 隨機字串，用來驗證 API 請求（可自行設定）
ADMIN_TOKEN=change_this_to_a_random_secret_string

# 伺服器 Port
PORT=3000

# 上下班時間（24hr 格式）
WORK_START=09:00
WORK_END=18:00
